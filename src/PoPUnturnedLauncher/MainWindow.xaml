<Window x:Class="PoPUnturnedLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PoPUnturnedLauncher"
        mc:Ignorable="d"
        Title="PoPUnturned Launcher" 
        Height="550" 
        Width="850"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="Assets/icon.ico">

    <Window.Resources>
        <!-- Estilo General de Texto -->
        <Style x:Key="SleekTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold, Segoe UI, Arial"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
        </Style>

        <!-- Estilo del Botón de Control (Cerrar / Minimizar / Opciones) -->
        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#88FFFFFF"/>
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#25FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo del Botón Cerrar Específico (Rojo al Hover) -->
        <Style x:Key="WindowCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#88FFFFFF"/>
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo del Botón JUGAR (Premium Glow) -->
        <Style x:Key="PlayButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFE300" Offset="0"/>     <!-- Amarillo -->
                        <GradientStop Color="#FF3A00" Offset="0.5"/>   <!-- Naranja Rojo -->
                        <GradientStop Color="#A30000" Offset="1"/>     <!-- Rojo Oscuro -->
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI, Impact, Arial"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="30" 
                                BorderThickness="1" 
                                BorderBrush="#50FFFFFF"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect x:Name="shadow" Color="#FF3A00" BlurRadius="15" Opacity="0.5" ShadowDepth="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="1"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.04" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.04" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="BlurRadius" To="25" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="Opacity" To="0.85" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="BlurRadius" To="15" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="Opacity" To="0.5" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo de Botón Primario Pequeño (Para Modales - Altura 38) -->
        <Style x:Key="SmallPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF6A00" Offset="0.0"/>
                        <GradientStop Color="#EE0000" Offset="1.0"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="19" 
                                BorderThickness="1" 
                                BorderBrush="#50FFFFFF"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect x:Name="shadow" Color="#FF3A00" BlurRadius="10" Opacity="0.5" ShadowDepth="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="1"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FF7A10" Offset="0.0"/>
                                            <GradientStop Color="#FF1111" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo de Botón Secundario (Gris Oscuro Glassmorphic) -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#25FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="19" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45FFFFFF"/>
                                <Setter Property="BorderBrush" Value="#60FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo de Botón Acción Primario en Modales (Total Legibilidad y Glow) -->
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFE300" Offset="0"/>     <!-- Amarillo -->
                        <GradientStop Color="#FF3A00" Offset="0.5"/>   <!-- Naranja Rojo -->
                        <GradientStop Color="#A30000" Offset="1"/>     <!-- Rojo Oscuro -->
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold, Segoe UI, Arial"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="19" 
                                BorderThickness="1" 
                                BorderBrush="#50FFFFFF"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect x:Name="shadow" Color="#FF3A00" BlurRadius="10" Opacity="0.5" ShadowDepth="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="1"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.95"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo de Botón Social (Icono Redondo con Gráfico Vectorial) -->
        <Style x:Key="SocialButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="21" 
                                BorderThickness="1" 
                                BorderBrush="#20FFFFFF"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#40FFFFFF"/>
                                <Setter Property="BorderBrush" Value="#50FFFFFF"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.1" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.1" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo de Input / TextBox para Opciones -->
        <Style x:Key="SleekTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#20000000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#FF3A00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Fondo Degradado Radial de Lujo (Estilo PoP) -->
        <Border CornerRadius="16">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.0" GradientOrigin="0.5,0.0" RadiusX="1.3" RadiusY="1.3">
                    <GradientStop Color="#3A0808" Offset="0"/>       <!-- Brillo rojo oscuro central superior -->
                    <GradientStop Color="#141311" Offset="0.55"/>     <!-- Transición carbón -->
                    <GradientStop Color="#090909" Offset="1"/>        <!-- Negro profundo lateral e inferior -->
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- Efecto de Capa de Vidrio y Borde de Ventana -->
        <Border CornerRadius="16" BorderThickness="1" BorderBrush="#25FFFFFF">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Color="Black" Opacity="0.75" Direction="270" ShadowDepth="4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>     <!-- Cabecera / Barra de arrastre -->
                    <RowDefinition Height="*"/>      <!-- Contenido Principal -->
                    <RowDefinition Height="60"/>     <!-- Pie de página -->
                </Grid.RowDefinitions>

                <!-- 1. BARRA DE TÍTULO PERSONALIZADA -->
                <Grid Grid.Row="0" Background="#10000000" MouseDown="Header_MouseDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Título -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                        <Image Source="Assets/logo.png" Width="18" Height="18" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Style="{StaticResource SleekTextStyle}" Text="PoPUnturned Launcher" FontSize="12" Opacity="0.8"/>
                    </StackPanel>

                    <!-- Botones Música / Opciones / Minimizar / Cerrar -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Botón Música -->
                        <Button x:Name="MusicToggleButton" Style="{StaticResource WindowControlButtonStyle}" ToolTip="Música de ambiente Lo-Fi (Silenciar / Activar)" Click="MusicToggle_Click">
                            <TextBlock x:Name="MusicIconText" Text="🎵" FontSize="12" Foreground="#FFE300"/>
                        </Button>
                        <!-- Botón Opciones -->
                        <Button Style="{StaticResource WindowControlButtonStyle}" ToolTip="Opciones y Configuración" Click="Options_Click">
                            <Path Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6-3.6z" 
                                  Fill="#BBFFFFFF" Width="14" Height="14" Stretch="Uniform"/>
                        </Button>
                        <!-- Botón Minimizar -->
                        <Button Style="{StaticResource WindowControlButtonStyle}" ToolTip="Minimizar" Click="Minimize_Click">
                            <Rectangle Width="10" Height="1.5" Fill="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                        <!-- Botón Cerrar -->
                        <Button Style="{StaticResource WindowCloseButtonStyle}" Click="Close_Click">
                            <TextBlock Text="✕" FontFamily="Segoe UI" FontSize="12" Foreground="White"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- 2. CONTENIDO PRINCIPAL -->
                <Grid Grid.Row="1" Margin="30,10,30,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>         <!-- Panel Izquierdo: Controles -->
                        <ColumnDefinition Width="250"/>       <!-- Panel Derecho: Lista de Jugadores -->
                    </Grid.ColumnDefinitions>

                    <!-- PANEL IZQUIERDO: CONTROLES DEL LAUNCHER -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>   <!-- Logo -->
                            <RowDefinition Height="*"/>      <!-- Datos Servidor -->
                            <RowDefinition Height="Auto"/>   <!-- Botones de Acción -->
                        </Grid.RowDefinitions>

                        <!-- A. LOGO Y DETALLES DEL LOGO -->
                        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,10">
                            <Image Source="Assets/logo.png" Height="170" RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Effect>
                                    <DropShadowEffect BlurRadius="25" Color="Black" Opacity="0.5" ShadowDepth="3"/>
                                </Image.Effect>
                            </Image>
                        </StackPanel>

                        <!-- B. ESTADO DEL SERVIDOR Y CONTADORES -->
                        <Grid Grid.Row="1" VerticalAlignment="Center" Margin="0,10,0,10">
                            <Border Background="#12FFFFFF" CornerRadius="12" BorderThickness="1" BorderBrush="#15FFFFFF" HorizontalAlignment="Center" Padding="25,12">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- Indicador LED de Estado -->
                                    <Ellipse x:Name="ServerStatusLed" Width="10" Height="10" Fill="#FF5555" Margin="0,0,10,0">
                                        <Ellipse.Effect>
                                            <DropShadowEffect x:Name="LedGlow" Color="#FF5555" BlurRadius="8" ShadowDepth="0"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    
                                    <!-- Texto de Estado -->
                                    <TextBlock x:Name="ServerStatusText" Style="{StaticResource SleekTextStyle}" Text="Buscando servidor..." FontSize="14" Margin="0,0,20,0"/>

                                    <!-- Divisor -->
                                    <Border BorderThickness="0,0,1,0" BorderBrush="#30FFFFFF" Height="16" Margin="0,0,20,0"/>

                                    <!-- Jugadores Conectados -->
                                    <TextBlock x:Name="ServerPlayersText" Style="{StaticResource SleekTextStyle}" Text="-- / -- Jugadores" FontSize="14" Opacity="0.9"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- C. BOTÓN PRINCIPAL JUGAR -->
                        <Grid Grid.Row="2" Margin="0,0,0,30">
                            <Button Style="{StaticResource PlayButtonStyle}" Width="320" HorizontalAlignment="Center" Click="Play_Click">
                                <TextBlock Text="JUGAR"/>
                            </Button>
                        </Grid>
                    </Grid>

                    <!-- PANEL DERECHO: LISTA JUGADORES EN LÍNEA -->
                    <Border Grid.Column="1" Background="#0CFFFFFF" CornerRadius="12" BorderThickness="1" BorderBrush="#15FFFFFF" Margin="15,10,0,30">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- Título -->
                                <RowDefinition Height="*"/>      <!-- Lista Scrollable -->
                            </Grid.RowDefinitions>
                            
                            <!-- Título de la lista -->
                            <TextBlock Grid.Row="0" Style="{StaticResource SleekTextStyle}" Text="JUGADORES EN LÍNEA" FontSize="12" FontWeight="Bold" Foreground="#FFE300" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            
                            <!-- ListBox para los nombres -->
                            <ListBox x:Name="PlayersListBox" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="White" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="2,4">
                                            <TextBlock Text="👤" Foreground="#88FFFFFF" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding}" Style="{StaticResource SleekTextStyle}" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Focusable" Value="False"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="6,4">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#15FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>

                            <!-- Texto alternativo de cargando / offline / vacío -->
                            <TextBlock x:Name="NoPlayersText" Grid.Row="1" Style="{StaticResource SleekTextStyle}" Text="Cargando..." FontSize="12" Opacity="0.5" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Visibility="Visible"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 3. PIE DE PÁGINA (Footer con Iconos Reales Vectoriales) -->
                <Grid Grid.Row="2" Background="#0CFFFFFF" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Enlaces de Redes Sociales con Iconos Vectoriales -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="25,0,0,0">
                        <!-- Discord -->
                        <Button Style="{StaticResource SocialButtonStyle}" Margin="0,0,8,0" ToolTip="Discord" Click="Discord_Click">
                            <Path Data="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994.021-.041.001-.09-.041-.106a13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.061 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.893.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.028zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z" 
                                  Fill="#5865F2" Width="20" Height="20" Stretch="Uniform"/>
                        </Button>
                        <!-- Página Web -->
                        <Button Style="{StaticResource SocialButtonStyle}" Margin="0,0,8,0" ToolTip="Sitio Web" Click="Website_Click">
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" 
                                  Fill="#4A90E2" Width="18" Height="18" Stretch="Uniform"/>
                        </Button>
                        <!-- YouTube -->
                        <Button Style="{StaticResource SocialButtonStyle}" Margin="0,0,8,0" ToolTip="YouTube" Click="Youtube_Click">
                            <Path Data="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" 
                                  Fill="#FF0000" Width="20" Height="20" Stretch="Uniform"/>
                        </Button>
                        <!-- TikTok -->
                        <Button Style="{StaticResource SocialButtonStyle}" Margin="0,0,8,0" ToolTip="TikTok" Click="Tiktok_Click">
                            <Path Data="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64c.29 0 .56.04.82.12V9.38a6.34 6.34 0 0 0-1-.08A6.34 6.34 0 0 0 3 15.64a6.34 6.34 0 0 0 10.83 4.47 6.29 6.29 0 0 0 1.73-4.44V8.87a8.16 8.16 0 0 0 4.82 1.56V6.98a4.85 4.85 0 0 1-.79-.29z" 
                                  Fill="#25F4EE" Width="18" Height="18" Stretch="Uniform"/>
                        </Button>
                        <!-- Twitter/X -->
                        <Button Style="{StaticResource SocialButtonStyle}" Margin="0,0,8,0" ToolTip="Twitter / X" Click="Twitter_Click">
                            <Path Data="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" 
                                  Fill="White" Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <!-- Instagram -->
                        <Button Style="{StaticResource SocialButtonStyle}" ToolTip="Instagram" Click="Instagram_Click">
                            <Path Data="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" 
                                  Fill="#E1306C" Width="18" Height="18" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>

                    <!-- Información de Versión / Créditos -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,25,0">
                        <TextBlock Style="{StaticResource SleekTextStyle}" Text="Estado de Mods:" FontSize="11" Opacity="0.6" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="WorkshopStatusText" Style="{StaticResource SleekTextStyle}" Text="Verificando..." FontSize="11" Foreground="#FFCC00" VerticalAlignment="Center" Margin="0,0,25,0"/>
                        
                        <TextBlock Style="{StaticResource SleekTextStyle}" Text="v1.0.0" FontSize="12" Opacity="0.5" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- 4. MODAL OVERLAY DE OPCIONES / CONFIGURACIÓN -->
                <Grid x:Name="OptionsModal" Grid.RowSpan="3" Background="#D50A0A0C" Visibility="Collapsed">
                    <Border Width="680" MaxHeight="570" VerticalAlignment="Center" HorizontalAlignment="Center" Background="#1C1B20" CornerRadius="16" BorderThickness="1" BorderBrush="#35FFFFFF" Padding="25,20,25,25">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="40" Color="Black" Opacity="0.85" ShadowDepth="10"/>
                        </Border.Effect>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Focusable="False">
                            <StackPanel Margin="0,0,5,0">
                                <!-- Cabecera del Modal -->
                                <Grid Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6-3.6z" 
                                              Fill="#FF3A00" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Style="{StaticResource SleekTextStyle}" Text="OPCIONES Y CONFIGURACIÓN" FontSize="16" FontWeight="Bold"/>
                                    </StackPanel>
                                    
                                    <Button Style="{StaticResource WindowCloseButtonStyle}" HorizontalAlignment="Right" Click="CloseOptions_Click">
                                        <TextBlock Text="✕" FontSize="14" Foreground="White"/>
                                    </Button>
                                </Grid>

                                <!-- Divisor -->
                                <Border BorderThickness="0,0,0,1" BorderBrush="#20FFFFFF" Margin="0,0,0,15"/>

                                <!-- SECCIÓN 1: VOLUMEN DE VEHÍCULOS -->
                                <StackPanel Margin="0,0,0,15">
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Style="{StaticResource SleekTextStyle}" Text="🔊 Volumen del Motor de Vehículos" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="VehicleVolumeText" Style="{StaticResource SleekTextStyle}" Text="100%" FontSize="13" FontWeight="Bold" Foreground="#FFE300" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <TextBlock Style="{StaticResource SleekTextStyle}" Text="Modifica el parámetro Vehicle_Engine_Volume_Multiplier en Preferences.json" FontSize="11" Opacity="0.6" Margin="0,0,0,8"/>
                                    <Slider x:Name="VehicleVolumeSlider" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="VehicleVolumeSlider_ValueChanged" Height="24" Cursor="Hand"/>
                                </StackPanel>

                                <!-- SECCIÓN 2: VOLUMEN MÚSICA DE AMBIENTE LO-FI -->
                                <StackPanel Margin="0,0,0,15">
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Style="{StaticResource SleekTextStyle}" Text="🎵 Volumen de Música de Ambiente (Lo-Fi Chill)" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="MusicVolumeText" Style="{StaticResource SleekTextStyle}" Text="50%" FontSize="13" FontWeight="Bold" Foreground="#FFE300" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <TextBlock Style="{StaticResource SleekTextStyle}" Text="Ajusta el volumen de la música relajante de fondo del launcher" FontSize="11" Opacity="0.6" Margin="0,0,0,8"/>
                                    <Slider x:Name="MusicVolumeSlider" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="MusicVolumeSlider_ValueChanged" Height="24" Cursor="Hand"/>
                                </StackPanel>

                                <!-- SECCIÓN 3: RUTA UNTURNED -->
                                <StackPanel Margin="0,0,0,15">
                                    <TextBlock Style="{StaticResource SleekTextStyle}" Text="📁 Carpeta de Unturned (Contiene Preferences.json)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Style="{StaticResource SleekTextStyle}" Text="Selecciona si Unturned está instalado en otro disco o ruta personalizada." FontSize="11" Opacity="0.6" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="UnturnedPathTextBox" Style="{StaticResource SleekTextBoxStyle}"/>
                                        <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="Buscar..." Width="90" Height="32" Margin="8,0,0,0" Click="BrowseUnturned_Click"/>
                                    </Grid>
                                </StackPanel>

                                <!-- SECCIÓN 4: RUTA MODS / WORKSHOP -->
                                <StackPanel Margin="0,0,0,18">
                                    <TextBlock Style="{StaticResource SleekTextStyle}" Text="📦 Carpeta de Mods de Workshop (ID: 304930)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Style="{StaticResource SleekTextStyle}" Text="Ruta del contenido de la Workshop para limpiar mods cuando sea necesario." FontSize="11" Opacity="0.6" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="WorkshopPathTextBox" Style="{StaticResource SleekTextBoxStyle}"/>
                                        <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="Buscar..." Width="90" Height="32" Margin="8,0,0,0" Click="BrowseWorkshop_Click"/>
                                    </Grid>
                                </StackPanel>

                                <!-- BOTONES DE ACCIÓN INFERIORES -->
                                <Grid Margin="0,15,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Restablecer Autodetección -->
                                    <Button Grid.Column="0" Style="{StaticResource SecondaryButtonStyle}" Content="Restablecer Autodetección" Padding="15,0" Height="38" Click="ResetOptions_Click"/>

                                    <!-- Grupo Derecho: Borrar Mods + Guardar y Aplicar -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <!-- Botón Limpiar Mods desde Opciones -->
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Padding="15,0" Height="38" Click="DeleteMods_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🧹" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Borrar Mods" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Botón Guardar y Aplicar -->
                                        <Button Style="{StaticResource SmallPrimaryButtonStyle}" Content="Guardar y Aplicar" Padding="20,0" Height="38" Click="SaveOptions_Click"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- 5. MODAL OVERLAY DE ACTUALIZACIÓN DISPONIBLE -->
                <Grid x:Name="UpdateModal" Grid.RowSpan="3" Background="#E00A0A0C" Visibility="Collapsed">
                    <Border Width="550" VerticalAlignment="Center" HorizontalAlignment="Center" Background="#1C1B20" CornerRadius="16" BorderThickness="1" BorderBrush="#35FFFFFF" Padding="25">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="40" Color="Black" Opacity="0.85" ShadowDepth="10"/>
                        </Border.Effect>

                        <StackPanel>
                            <!-- Cabecera -->
                            <Grid Margin="0,0,0,15">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🚀" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Style="{StaticResource SleekTextStyle}" Text="¡NUEVA ACTUALIZACIÓN DISPONIBLE!" FontSize="15" FontWeight="Bold" Foreground="#FFE300"/>
                                </StackPanel>
                                <TextBlock x:Name="NewVersionText" Style="{StaticResource SleekTextStyle}" Text="v1.0.1" FontSize="13" FontWeight="Bold" Foreground="#FF3A00" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Divisor -->
                            <Border BorderThickness="0,0,0,1" BorderBrush="#20FFFFFF" Margin="0,0,0,15"/>

                            <TextBlock Style="{StaticResource SleekTextStyle}" Text="Novedades de la versión:" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            
                            <!-- Caja de Novedades / Release Notes -->
                            <Border Background="#20000000" CornerRadius="8" BorderThickness="1" BorderBrush="#25FFFFFF" Padding="12" Margin="0,0,0,20" MaxHeight="140">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="ReleaseNotesText" Style="{StaticResource SleekTextStyle}" Text="Cargando novedades..." FontSize="12" Opacity="0.85" TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </Border>

                            <!-- Contenedor de la Barra de Progreso de Descarga -->
                            <StackPanel x:Name="UpdateProgressPanel" Visibility="Collapsed" Margin="0,0,0,20">
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Style="{StaticResource SleekTextStyle}" Text="Descargando e instalando actualización..." FontSize="12"/>
                                    <TextBlock x:Name="UpdatePercentText" Style="{StaticResource SleekTextStyle}" Text="0%" FontSize="12" FontWeight="Bold" Foreground="#FFE300" HorizontalAlignment="Right"/>
                                </Grid>
                                <ProgressBar x:Name="UpdateProgressBar" Height="10" Minimum="0" Maximum="100" Value="0" Foreground="#FF3A00" Background="#30FFFFFF" BorderThickness="0"/>
                            </StackPanel>

                            <!-- Botones de Acción -->
                            <Grid x:Name="UpdateButtonsPanel" Margin="0,5,0,0">
                                <Button x:Name="SkipUpdateButton" Style="{StaticResource SecondaryButtonStyle}" Content="Más tarde" Width="140" Height="38" HorizontalAlignment="Left" Click="SkipUpdate_Click"/>
                                <Button x:Name="ApplyUpdateButton" Style="{StaticResource PrimaryActionButtonStyle}" Content="Actualizar Ahora" Padding="25,0" Height="38" HorizontalAlignment="Right" Click="ApplyUpdate_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
